        {
          "expr": "sum(saferx_audit_decisions_total{decision=\"IGNORED\"})",
          "legendFormat": "IGNORED",
          "refId": "B",
          "datasource": null
        },
        {
          "expr": "sum(saferx_audit_decisions_total{decision=\"OVERRIDE\"})",
          "legendFormat": "OVERRIDE",
          "refId": "C",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "piechart",
      "id": 12,
      "title": "Prescriptions safe vs avec alertes",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(saferx_prescriptions_total{status=\"safe\"})",
          "legendFormat": "Safe (0 alerte)",
          "refId": "A",
          "datasource": null
