      "title": "Erreurs HTTP 4xx / 5xx",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"4..\"}[5m]) * 60",
          "legendFormat": "4xx",
          "refId": "A",
          "datasource": null
        },
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) * 60",
          "legendFormat": "5xx",
          "refId": "B",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
      "id": 40,
      "title": "CPU par container (%)",
      "description": "Utilisation CPU de chaque container SafeRx (moyenne sur 1 min)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"saferxai_.*\"}[1m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Mémoire par container (Mo)",
      "description": "Consommation mémoire RSS de chaque container",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "container_memory_rss{name=~\"saferxai_.*\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "Réseau — trafic entrant/sortant (Ko/s)",
      "description": "Trafic réseau par container",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"saferxai_.*\"}[1m]) / 1024",
          "legendFormat": "↓ {{name}}",
          "refId": "A",
          "datasource": null
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"saferxai_.*\"}[1m]) / 1024",
          "legendFormat": "↑ {{name}}",
          "refId": "B",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "stat",
      "id": 43,
      "title": "Containers actifs",
      "description": "Nombre de containers saferxai en cours d'exécution",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\"saferxai_.*\"})",
          "legendFormat": "Containers",
          "refId": "A",
          "datasource": null
        }
      ],
      "datasource": null
    }
