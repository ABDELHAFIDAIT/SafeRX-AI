  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Prescriptions totales",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(saferx_prescriptions_total)",
          "legendFormat": "Total",
          "refId": "A",
          "datasource": null
        }
      ],
      "datasource": null
    },
