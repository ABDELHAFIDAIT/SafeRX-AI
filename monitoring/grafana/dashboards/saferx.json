    {
      "type": "timeseries",
      "id": 10,
      "title": "Alertes CDS par type (taux par minute)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"INTERACTION\"}[5m]) * 60",
          "legendFormat": "INTERACTION",
          "refId": "A",
          "datasource": null
        },
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"ALLERGY\"}[5m]) * 60",
          "legendFormat": "ALLERGY",
          "refId": "B",
          "datasource": null
        },
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"REDUNDANT_DCI\"}[5m]) * 60",
          "legendFormat": "REDUNDANT_DCI",
          "refId": "C",
          "datasource": null
        },
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"RENAL\"}[5m]) * 60",
          "legendFormat": "RENAL",
          "refId": "D",
          "datasource": null
        },
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"CONTRA_INDICATION\"}[5m]) * 60",
          "legendFormat": "CONTRA_INDICATION",
          "refId": "E",
          "datasource": null
        },
        {
          "expr": "rate(saferx_cds_alerts_total{alert_type=\"POSOLOGY\"}[5m]) * 60",
          "legendFormat": "POSOLOGY",
          "refId": "F",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "piechart",
      "id": 11,
      "title": "Décisions médecin",
