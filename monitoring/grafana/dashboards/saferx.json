    {
      "type": "stat",
      "id": 4,
      "title": "Taux d'override (%)",
      "description": "% de décisions OVERRIDE parmi toutes les décisions",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 40
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(saferx_audit_decisions_total{decision=\"OVERRIDE\"}) / sum(saferx_audit_decisions_total)",
          "legendFormat": "Override %",
          "refId": "A",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "stat",
      "id": 6,
