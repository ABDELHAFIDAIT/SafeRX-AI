          "expr": "sum(saferx_prescriptions_total{status=\"alerts\"})",
          "legendFormat": "Avec alertes",
          "refId": "B",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "Latence API — p50 / p95 / p99 (ms)",
      "description": "Percentiles de latence des endpoints FastAPI",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=~\"/api/.*\"}[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": null
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=~\"/api/.*\"}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": null
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=~\"/api/.*\"}[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Requêtes HTTP par endpoint (req/min)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/api/prescriptions/\"}[5m]) * 60",
          "legendFormat": "POST /prescriptions",
          "refId": "A",
          "datasource": null
        },
        {
          "expr": "rate(http_requests_total{handler=\"/api/audit/bulk\"}[5m]) * 60",
          "legendFormat": "POST /audit/bulk",
          "refId": "B",
          "datasource": null
        },
        {
          "expr": "rate(http_requests_total{handler=\"/api/patients/{patient_id}\"}[5m]) * 60",
          "legendFormat": "GET /patients",
          "refId": "C",
          "datasource": null
        },
        {
          "expr": "rate(http_requests_total{handler=\"/api/auth/login\"}[5m]) * 60",
          "legendFormat": "POST /auth/login",
          "refId": "D",
          "datasource": null
        }
      ],
      "datasource": null
    },
    {
      "type": "timeseries",
